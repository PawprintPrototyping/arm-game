[Unit]
Description=Opensauce23 Targets MQTT Consumer
After=syslog.target network.target

[Service]
Environment="MQTT_HOST=arm-display"
Environment="DEBUG=1"
Environment="DEVICE=/dev/ttyTargets"
ExecStart=/home/pi/opensauce23/venv/bin/python /home/pi/opensauce23/motion/target_scoring_mqtt_consumer.py
Type=simple
Restart=always

[Install]
WantedBy=multi-user.target

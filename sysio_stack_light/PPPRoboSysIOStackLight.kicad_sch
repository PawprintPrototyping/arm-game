  (text "Leaving E-Stop completely seperate for now.\nIn the event of E-Stop not working (jumpered out),\nwe need to still clearly indicate if the arm has power.\nWe could switch off blue/green, but I want to know\nthe state of the controller."
    (at 117.475 63.5 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid 312f1797-da05-4fba-bc62-cfe325d306dc)
  )
  (text "BLUE: No arm power, no controller power.\nGREEN: No arm power, yes controller power.\nYELLOW: Yes arm power.\nRED: External E-Stop hit.\nRED + YELLOW: External E-Stop hit but arm is *NOT* off!"
    (at 117.475 31.75 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid 73fc7f50-e636-4026-a27b-e2bb15cdbbe2)
  )
  (text "Potential between controller ground and isolated SYSIO circuit must never exceed 50v."
    (at 43.18 172.085 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid 8f7895e6-e717-4e06-a64a-04d33a03d42c)
  )
  (text "External Pendant" (at 211.455 124.46 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid b0a51f2b-1fff-4c3f-b5f3-88dc6d8def01)
  )
  (text "E-Stop is normally closed." (at 241.3 124.46 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid e37f6975-2b1f-4eb9-9eb9-384818f4e8a0)
  )

